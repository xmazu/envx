{
  "name": "@openenvx/admin",
  "version": "0.1.0",
  "type": "module",
  "author": {
    "email": "xmazu@yahoo.com",
    "name": "xmazu"
  },
  "description": "Standalone admin panel",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && swc ./src -d ./dist --strip-leading-paths && tsc --emitDeclarationOnly --outDir dist && tsc-alias -p tsconfig.json && tailwindcss -i ./src/styles/globals.css --content './src/**/*.{tsx,ts}' -o ./dist/styles.css",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "dev": "swc ./src -d ./dist --strip-leading-paths --watch",
    "typecheck": "tsc --noEmit || true",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "jose": "^6.0.10",
    "lucide-react": "^1.7.0",
    "pluralize": "^8.0.0",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^25.3.5",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "next": "^16.2.1",
    "postcss-cli": "^11.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-table": "^8.21.3",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "zod": "^4.3.6"
  },
  "exports": {
    "./client": {
      "types": "./dist/exports/client.d.ts",
      "import": "./dist/exports/client.js",
      "default": "./dist/exports/client.js"
    },
    "./server": {
      "types": "./dist/exports/server.d.ts",
      "import": "./dist/exports/server.js",
      "default": "./dist/exports/server.js"
    },
    "./rsc": {
      "types": "./dist/exports/rsc.d.ts",
      "import": "./dist/exports/rsc.js",
      "default": "./dist/exports/rsc.js"
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "default": "./dist/styles.css"
    },
    "./client/styles.css": {
      "import": "./dist/styles.css",
      "default": "./dist/styles.css"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
