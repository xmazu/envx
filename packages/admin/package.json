{
  "name": "@openenvx/admin",
  "version": "0.1.3",
  "author": "OpenEnvX",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rolldown": "^1.0.0-rc.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@refinedev/core": "^5.0.10",
    "@refinedev/nextjs-router": "^7.0.5",
    "@refinedev/react-hook-form": "^5.0.4",
    "@refinedev/react-table": "^6.0.1",
    "@refinedev/simple-rest": "^6.0.1",
    "@tanstack/react-table": "^8.21.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": "^16.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./styles.css": {
      "import": "./dist/styles.css"
    }
  },
  "description": "Standalone admin panel using PostgREST, Refine and shadcn/ui",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rolldown -c && tsc --emitDeclarationOnly || true",
    "dev": "rolldown -c --watch",
    "typecheck": "tsc --noEmit || true",
    "prepublishOnly": "bun run build"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@refinedev/nextjs-router": "^7.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "postgres": "^3.4.5",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "tailwind-merge": "^2.5.0"
  }
}
