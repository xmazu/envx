#!/usr/bin/env node
/**
 * Drizzle to Refine Resource Config Generator
 * 
 * This script analyzes the Drizzle schema and generates resource configuration
 * for the Refine admin panel. Run it after adding new tables to your schema.
 * 
 * Usage:
 *   bun run generate:resources
 * 
 * The generated config will be written to lib/resource-config.ts
 * You can customize the config after generation.
 */

import * as fs from 'node:fs';
import * as path from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));

// Icons mapping for common table names
const iconMapping: Record<string, string> = {
  users: 'Users',
  user: 'Users',
  posts: 'FileText',
  post: 'FileText',
  articles: 'FileText',
  article: 'FileText',
  products: 'Package',
  product: 'Package',
  orders: 'ShoppingCart',
  order: 'ShoppingCart',
  customers: 'UserCircle',
  customer: 'UserCircle',
  categories: 'FolderTree',
  category: 'FolderTree',
  tags: 'Tags',
  tag: 'Tags',
  comments: 'MessageSquare',
  comment: 'MessageSquare',
  settings: 'Settings',
  dashboard: 'LayoutDashboard',
};

// Tables to exclude from admin panel
const excludedTables = ['admin_sessions', 'migrations', '_drizzle_migrations'];

function extractTableNames(schemaContent: string): string[] {
  const tableRegex = /export\s+const\s+(\w+)\s*=\s*pgTable/g;
  const tables: string[] = [];
  let match;

  while ((match = tableRegex.exec(schemaContent)) !== null) {
    const tableName = match[1];
    if (!excludedTables.includes(tableName)) {
      tables.push(tableName);
    }
  }

  return tables;
}

function generateResourceConfig(tables: string[]): string {
  const imports = [
    `import type { ResourceProps } from "@refinedev/core";`,
    `import {`,
    `  LayoutDashboard,`,
    `  Users,`,
    `  FileText,`,
    `  Settings,`,
    `  Package,`,
    `  ShoppingCart,`,
    `  UserCircle,`,
    `  FolderTree,`,
    `  Tags,`,
    `  MessageSquare,`,
    `  type LucideIcon,`,
    `} from "lucide-react";`,
    ``,
  ];

  const resourceInterface = [
    `export interface ResourceConfig extends ResourceProps {`,
    `  icon?: LucideIcon;`,
    `  label: string;`,
    `  hidden?: boolean;`,
    `}`,
    ``,
  ];

  const resourcesArray = [
    `export const resources: ResourceConfig[] = [`,
    `  {`,
    `    name: "dashboard",`,
    `    list: "/",`,
    `    label: "Dashboard",`,
    `    icon: LayoutDashboard,`,
    `    hidden: false,`,
    `  },`,
  ];

  for (const table of tables) {
    const iconName = iconMapping[table.toLowerCase()] || 'FileText';
    const label = table.charAt(0).toUpperCase() + table.slice(1);

    resourcesArray.push(`  {`);
    resourcesArray.push(`    name: "${table}",`);
    resourcesArray.push(`    list: "/${table}",`);
    resourcesArray.push(`    create: "/${table}/create",`);
    resourcesArray.push(`    edit: "/${table}/edit/:id",`);
    resourcesArray.push(`    show: "/${table}/show/:id",`);
    resourcesArray.push(`    label: "${label}",`);
    resourcesArray.push(`    icon: ${iconName},`);
    resourcesArray.push(`  },`);
  }

  resourcesArray.push(`  {`);
  resourcesArray.push(`    name: "settings",`);
  resourcesArray.push(`    list: "/settings",`);
  resourcesArray.push(`    label: "Settings",`);
  resourcesArray.push(`    icon: Settings,`);
  resourcesArray.push(`  },`);
  resourcesArray.push(`];`);
  resourcesArray.push(``);

  const helperFunctions = [
    `export function getResourceByName(name: string): ResourceConfig | undefined {`,
    `  return resources.find((r) => r.name === name);`,
    `}`,
    ``,
    `export function getVisibleResources(): ResourceConfig[] {`,
    `  return resources.filter((r) => !r.hidden);`,
    `}`,
    ``,
  ];

  const comment = [
    `/**`,
    ` * GENERATED FILE - DO NOT EDIT DIRECTLY`,
    ` * Generated by scripts/generate-resources.ts`,
    ` * Based on Drizzle schema from @{{projectName}}/db`,
    ` * `,
    ` * You can customize this file after generation:`,
    ` * - Add/edit icons for your tables`,
    ` * - Hide resources by setting hidden: true`,
    ` * - Add custom meta properties`,
    ` * - Reorder resources`,
    ` */`,
    ``,
  ];

  return [...comment, ...imports, ...resourceInterface, ...resourcesArray, ...helperFunctions].join(
    '\n'
  );
}

async function main() {
  console.log('🔍 Analyzing Drizzle schema...\n');

  // Look for schema file in the monorepo
  const possiblePaths = [
    path.join(__dirname, '..', '..', '..', 'db', 'src', 'schema.ts'),
    path.join(__dirname, '..', '..', '..', 'db', 'src', 'schema', 'index.ts'),
    path.join(__dirname, '..', 'node_modules', '@{{projectName}}', 'db', 'src', 'schema.ts'),
  ];

  let schemaPath: string | null = null;
  for (const p of possiblePaths) {
    if (fs.existsSync(p)) {
      schemaPath = p;
      break;
    }
  }

  if (!schemaPath) {
    console.error('❌ Could not find Drizzle schema file');
    console.log('Searched paths:');
    possiblePaths.forEach((p) => console.log(`  - ${p}`));
    console.log('\nPlease ensure your schema file exists in one of these locations.');
    process.exit(1);
  }

  console.log(`✓ Found schema at: ${schemaPath}\n`);

  const schemaContent = fs.readFileSync(schemaPath, 'utf-8');
  const tables = extractTableNames(schemaContent);

  console.log(`📊 Found ${tables.length} tables:`);
  tables.forEach((table) => console.log(`  - ${table}`));
  console.log('');

  if (tables.length === 0) {
    console.log('⚠️  No tables found in schema. Using default resources.');
    tables.push('users', 'posts');
  }

  const configContent = generateResourceConfig(tables);
  const outputPath = path.join(__dirname, '..', 'lib', 'resource-config.ts');

  // Backup existing file
  if (fs.existsSync(outputPath)) {
    const backupPath = `${outputPath}.backup.${Date.now()}`;
    fs.copyFileSync(outputPath, backupPath);
    console.log(`💾 Backed up existing config to: ${backupPath}\n`);
  }

  fs.writeFileSync(outputPath, configContent);
  console.log(`✅ Generated resource config: ${outputPath}\n`);
  console.log('🎉 Done! You can now customize the generated config if needed.');
  console.log('   Restart your dev server to see the changes.');
}

main().catch((err) => {
  console.error('❌ Error:', err);
  process.exit(1);
});
