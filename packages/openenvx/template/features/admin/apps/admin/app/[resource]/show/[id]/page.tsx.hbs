"use client";

import { useShow } from "@refinedev/core";
import { Button } from "@{{projectName}}/ui/components/button";
import { Card, CardContent, CardHeader, CardTitle } from "@{{projectName}}/ui/components/card";
import Link from "next/link";
import { ArrowLeft, Edit } from "lucide-react";

export default function ResourceShowPage({
  params,
}: {
  params: { resource: string; id: string };
}) {
  const { result, query } = useShow({
    resource: params.resource,
    id: params.id,
  });

  if (query.isLoading) {
    return <div>Loading...</div>;
  }

  const record = result;

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-4">
          <Link href={`/${params.resource}`}>
            <Button variant="ghost" size="icon">
              <ArrowLeft className="h-4 w-4" />
            </Button>
          </Link>
          <h1 className="text-3xl font-bold capitalize">{params.resource} Details</h1>
        </div>
        <Link href={`/${params.resource}/edit/${params.id}`}>
          <Button>
            <Edit className="mr-2 h-4 w-4" />
            Edit
          </Button>
        </Link>
      </div>

      <Card>
        <CardHeader>
          <CardTitle>Information</CardTitle>
        </CardHeader>
        <CardContent>
          <div className="space-y-4">
            {record &&
              Object.entries(record).map(([key, value]) => (
                <div key={key} className="border-b pb-2 last:border-0">
                  <p className="text-sm text-muted-foreground capitalize">{key}</p>
                  <p className="font-medium">
                    {typeof value === "object" ? JSON.stringify(value) : String(value)}
                  </p>
                </div>
              ))}
          </div>
        </CardContent>
      </Card>
    </div>
  );
}
