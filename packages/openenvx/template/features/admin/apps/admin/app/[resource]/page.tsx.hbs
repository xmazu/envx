"use client";

import { useTable } from "@refinedev/react-table";
import { type ColumnDef, flexRender } from "@tanstack/react-table";
import { useMemo } from "react";
import { useResourceParams } from "@refinedev/core";
import { Button } from "@{{projectName}}/ui/components/button";
import { Card, CardContent, CardHeader, CardTitle } from "@{{projectName}}/ui/components/card";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@{{projectName}}/ui/components/table";
import Link from "next/link";
import { Plus, Edit, Eye, Trash2 } from "lucide-react";

export default function ResourceListPage({ params }: { params: { resource: string } }) {
  const { resource } = useResourceParams({ resource: params.resource });

  const columns = useMemo<ColumnDef<any>[]>(
    () => [
      {
        id: "id",
        accessorKey: "id",
        header: "ID",
      },
      {
        id: "actions",
        header: "Actions",
        cell: ({ row }) => (
          <div className="flex items-center gap-2">
            <Link href={`/${params.resource}/show/${row.original.id}`}>
              <Button variant="ghost" size="icon">
                <Eye className="h-4 w-4" />
              </Button>
            </Link>
            <Link href={`/${params.resource}/edit/${row.original.id}`}>
              <Button variant="ghost" size="icon">
                <Edit className="h-4 w-4" />
              </Button>
            </Link>
            <Button variant="ghost" size="icon" className="text-destructive">
              <Trash2 className="h-4 w-4" />
            </Button>
          </div>
        ),
      },
    ],
    [params.resource]
  );

  const {
    reactTable,
    refineCore: { tableQuery },
  } = useTable({
    columns,
    refineCoreProps: {
      resource: params.resource,
    },
  });

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <h1 className="text-3xl font-bold capitalize">{params.resource}</h1>
        <Link href={`/${params.resource}/create`}>
          <Button>
            <Plus className="mr-2 h-4 w-4" />
            Create
          </Button>
        </Link>
      </div>

      <Card>
        <CardHeader>
          <CardTitle>All {params.resource}</CardTitle>
        </CardHeader>
        <CardContent>
          <Table>
            <TableHeader>
              {reactTable.getHeaderGroups().map((headerGroup: any) => (
                <TableRow key={headerGroup.id}>
                  {headerGroup.headers.map((header: any) => (
                    <TableHead key={header.id}>
                      {flexRender(header.column.columnDef.header, header.getContext())}
                    </TableHead>
                  ))}
                </TableRow>
              ))}
            </TableHeader>
            <TableBody>
              {reactTable.getRowModel().rows?.length ? (
                reactTable.getRowModel().rows.map((row: any) => (
                  <TableRow key={row.id}>
                    {row.getVisibleCells().map((cell: any) => (
                      <TableCell key={cell.id}>
                        {flexRender(cell.column.columnDef.cell, cell.getContext())}
                      </TableCell>
                    ))}
                  </TableRow>
                ))
              ) : (
                <TableRow>
                  <TableCell colSpan={columns.length} className="h-24 text-center">
                    No results.
                  </TableCell>
                </TableRow>
              )}
            </TableBody>
          </Table>
        </CardContent>
      </Card>
    </div>
  );
}
