import { betterAuth } from "better-auth";
import { drizzleAdapter } from "better-auth/adapters/drizzle";
import { db } from "@{{projectName}}/db";
import { admin } from "better-auth/plugins";

/**
 * Extended auth configuration with super admin support
 * 
 * This extends the base auth configuration with admin-specific features:
 * - Super admin role stored in separate table
 * - Admin-only authentication endpoints
 * - Role-based access control for admin panel
 */

export const auth = betterAuth({
  database: drizzleAdapter(db, {
    provider: "pg",
  }),
  plugins: [
    admin({
      adminRoles: ["super_admin", "admin"],
      defaultRole: "user",
    }),
  ],
  session: {
    expiresIn: 60 * 60 * 24 * 7, // 7 days
  },
});

export type Auth = typeof auth;

/**
 * Check if user is super admin
 */
export async function isSuperAdmin(userId: string): Promise<boolean> {
  const user = await db.query.user.findFirst({
    where: (user, { eq }) => eq(user.id, userId),
  });
  
  return user?.role === "super_admin" || user?.role === "admin";
}

/**
 * Middleware to protect admin routes
 */
export async function requireAdmin(userId: string | null): Promise<boolean> {
  if (!userId) return false;
  return isSuperAdmin(userId);
}
